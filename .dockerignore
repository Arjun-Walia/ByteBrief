# ByteBrief - Docker Ignore
# Files/folders to exclude from Docker build context

# Dependencies
node_modules
npm-debug.log
yarn-error.log

# Build outputs
dist
*.js.map

# Development
.env
.env.local
.env.*.local
*.local

# IDE/Editor
.vscode
.idea
*.swp
*.swo
*~

# Git
.git
.gitignore
.gitattributes

# Documentation
docs
*.md
!README.md

# Tests
tests
__tests__
coverage
.nyc_output
jest.config.js

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Docker
Dockerfile*
docker-compose*.yml
.docker
.dockerignore

# OS
.DS_Store
Thumbs.db

# Logs
logs
*.log

# Temp files
tmp
temp
*.tmp

# Client (if separate build)
client/node_modules
client/dist
client/.next
client/build

# Misc
*.tgz
*.tar.gz
*.zip
